# Python
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/
.eggs/
dist/
build/

# 毕设与本地论文工程
sysu-thesis-*/
答辩/

# LaTeX 辅助（根目录误生成）
main.aux
main.fdb_latexmk
main.fls
main.log
main.out
main.toc
main.lof
main.lot

# 备份与压缩包
*.rar
*.zip
_duplicate_root_modules_*.zip
_archive_pre_layout_*/

# IDE
.idea/

# 环境
.env
.venv/
venv/

# 数据目录占位：跟踪脚本与目录结构，不包含具体语料（本地生成）
